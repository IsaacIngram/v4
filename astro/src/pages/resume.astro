---
import PageLayout from '../layouts/PageLayout.astro';
import SearchModal from '../components/SearchModal.astro';
---

<PageLayout title="Resume" description="Isaac Ingram's resume." narrow>
  <div data-pagefind-body>
    <div class="flex items-start justify-between mb-10 gap-4 flex-wrap">
      <div>
        <h1 class="text-4xl font-bold text-cream mb-2">Resume</h1>
        <p class="text-cream/60">Take a brief look at my experience, skills, and education, or dive deeper by downloading my full resume.</p>
      </div>
      <a
        href="/isaac_ingram_resume.pdf"
        download
        class="flex items-center gap-2 px-4 py-2 border border-white/20 text-cream/80 hover:text-cream hover:border-white/40 rounded-lg text-sm transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download PDF
      </a>
    </div>

    <div class="space-y-12">

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Experience</h2>
        <div class="space-y-8">

          <div class="border-l-2 border-white/10 pl-6">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h3 class="font-semibold text-cream">Founding Software Engineer</h3>
              <span class="text-xs text-cream/40 font-mono whitespace-nowrap">August 2025 — Present</span>
            </div>
            <p class="text-sky/80 text-sm mb-3">GRID</p>
            <ul class="text-cream/60 text-sm leading-relaxed space-y-1 list-disc list-inside">
              <li>Develop system architecture for a SaaS app such that it is both lean and scalable</li>
              <li>Drive product development with a consumer-first mindset, thinking about how features actually work for customers</li>
              <li>Build the frontend, backend, and supporting services end-to-end, including an internal logging system that pipes structured events to Slack</li>
              <li>Collaborate across product and engineering to bring a concept to production</li>
            </ul>
            <div class="flex flex-wrap gap-2 mt-3">
              {['React', 'PostgreSQL', 'TypeScript', 'Supabase', 'Netlify'].map((tag) => (
                <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-cream/50 text-xs font-mono">{tag}</span>
              ))}
            </div>
          </div>

          <div class="border-l-2 border-white/10 pl-6">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h3 class="font-semibold text-cream">Co-Op, Software Engineering</h3>
              <span class="text-xs text-cream/40 font-mono whitespace-nowrap">May 2025 — Present</span>
            </div>
            <p class="text-sky/80 text-sm mb-3">Eoptic</p>
            <p class="text-cream/60 text-sm">Worked on embedded software for motors, sensors, and various imaging applications.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {['ESP-IDF', 'ROS', 'KiCAD', 'MQTT', 'NVIDIA Jetson'].map((tag) => (
                <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-cream/50 text-xs font-mono">{tag}</span>
              ))}
            </div>
          </div>

          <div class="border-l-2 border-white/10 pl-6">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h3 class="font-semibold text-cream">Co-Op, Application Software</h3>
              <span class="text-xs text-cream/40 font-mono whitespace-nowrap">May 2023 — April 2025</span>
            </div>
            <p class="text-sky/80 text-sm mb-3">Collins Aerospace</p>
            <p class="text-cream/60 text-sm">Worked on embedded avionics software, desktop applications, and devops tools.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {['Flask', 'Python', 'Selenium', 'C', 'Requirements Management'].map((tag) => (
                <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-cream/50 text-xs font-mono">{tag}</span>
              ))}
            </div>
          </div>

          <div class="border-l-2 border-white/10 pl-6">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h3 class="font-semibold text-cream">Lead Software Engineer</h3>
              <span class="text-xs text-cream/40 font-mono whitespace-nowrap">Sep 2023 — Jan 2024</span>
            </div>
            <p class="text-sky/80 text-sm mb-3">MakePlus</p>
            <p class="text-cream/60 text-sm">Worked on embedded software and UI for a music studio.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {['ESP-NOW', 'ESP32', 'Qt', 'Linux'].map((tag) => (
                <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-cream/50 text-xs font-mono">{tag}</span>
              ))}
            </div>
          </div>

        </div>
      </section>

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Skills</h2>
        <div class="space-y-4">
          <div>
            <p class="text-xs text-cream/40 uppercase tracking-widest mb-2">Languages</p>
            <div class="flex flex-wrap gap-2">
              {['C', 'Python', 'Java', 'C++', 'Matlab'].map((skill) => (
                <span class="px-3 py-1 rounded-full bg-white/8 border border-white/10 text-cream/70 text-sm">{skill}</span>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs text-cream/40 uppercase tracking-widest mb-2">Technologies</p>
            <div class="flex flex-wrap gap-2">
              {['ESP-IDF', 'Qt', 'Linux', 'Git', 'SVN', 'FreeRTOS', 'KiCAD', 'Jama', 'DOORS', 'Coverity'].map((skill) => (
                <span class="px-3 py-1 rounded-full bg-white/8 border border-white/10 text-cream/70 text-sm">{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Education</h2>
        <div class="border-l-2 border-white/10 pl-6">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
            <h3 class="font-semibold text-cream">BS Computer Science</h3>
            <span class="text-xs text-cream/40 font-mono whitespace-nowrap">May 2026</span>
          </div>
          <p class="text-sky/80 text-sm mb-2">Rochester Institute of Technology — Rochester, NY</p>
          <p class="text-cream/60 text-sm">Coursework in Data Management, Algorithms, Artificial Intelligence, Physics, and Computer Vision</p>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Activities</h2>
        <div class="space-y-8">

          <div class="border-l-2 border-white/10 pl-6">
            <h3 class="font-semibold text-cream mb-1">Computer Science House</h3>
            <p class="text-sky/80 text-sm mb-3">csh.rit.edu</p>
            <div class="space-y-3">
              <div>
                <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
                  <p class="text-cream/80 text-sm font-medium">President</p>
                  <span class="text-xs text-cream/40 font-mono whitespace-nowrap">June 2025 — May 2026</span>
                </div>
                <ul class="text-cream/60 text-sm leading-relaxed space-y-1 list-disc list-inside">
                  <li>Oversee house operations, running 3+ weekly meetings for over 65 active members</li>
                  <li>Secure donations from companies and alumni members</li>
                  <li>Work with companies to facilitate company floor visits to benefit our members</li>
                </ul>
              </div>
              <div>
                <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
                  <p class="text-cream/80 text-sm font-medium">Member</p>
                  <span class="text-xs text-cream/40 font-mono whitespace-nowrap">Aug 2022 — May 2026</span>
                </div>
                <ul class="text-cream/60 text-sm leading-relaxed space-y-1 list-disc list-inside">
                  <li>Living-learning community focused on sharing technical skills and knowledge</li>
                  <li>Empower and collaborate with other members on self-driven projects</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="border-l-2 border-white/10 pl-6">
            <h3 class="font-semibold text-cream mb-1">Sigma Chi | Lambda Kappa</h3>
            <p class="text-sky/80 text-sm mb-3">sigmachirit.com</p>
            <div class="space-y-3">
              <div>
                <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
                  <p class="text-cream/80 text-sm font-medium">Webmaster</p>
                  <span class="text-xs text-cream/40 font-mono whitespace-nowrap">April 2024 — May 2025</span>
                </div>
                <ul class="text-cream/60 text-sm leading-relaxed space-y-1 list-disc list-inside">
                  <li>Maintain chapter website, mailing lists, and Google Workspace for hundreds of actives and alumni</li>
                </ul>
              </div>
              <div>
                <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
                  <p class="text-cream/80 text-sm font-medium">Brother</p>
                  <span class="text-xs text-cream/40 font-mono whitespace-nowrap">March 2023 — May 2025</span>
                </div>
                <ul class="text-cream/60 text-sm leading-relaxed space-y-1 list-disc list-inside">
                  <li>Cultivate principles of friendship, justice, and learning with brothers</li>
                  <li>Host and attend philanthropy events to raise over $40,000 for the Huntsman Cancer Institute</li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </section>

    </div>
  </div>
</PageLayout>

<SearchModal />
