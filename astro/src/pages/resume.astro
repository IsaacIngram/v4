---
import PageLayout from '../layouts/PageLayout.astro';
import SearchModal from '../components/SearchModal.astro';
---

<PageLayout title="Resume" description="Isaac Ingram's resume." narrow>
  <div data-pagefind-body>
    <div class="flex items-start justify-between mb-10 gap-4 flex-wrap">
      <div>
        <h1 class="text-4xl font-bold text-cream mb-2">Resume</h1>
        <p class="text-cream/60">Experience, skills, and background.</p>
      </div>
      <a
        href="/resume.pdf"
        download
        class="flex items-center gap-2 px-4 py-2 border border-white/20 text-cream/80 hover:text-cream hover:border-white/40 rounded-lg text-sm transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download PDF
      </a>
    </div>

    <div class="space-y-12">

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Experience</h2>
        <div class="space-y-8">
          <div class="border-l-2 border-white/10 pl-6">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h3 class="font-semibold text-cream">Your Role</h3>
              <span class="text-xs text-cream/40 font-mono whitespace-nowrap">2024 — Present</span>
            </div>
            <p class="text-sky/80 text-sm mb-2">Company Name</p>
            <p class="text-cream/60 text-sm leading-relaxed">
              Describe your responsibilities and accomplishments here.
            </p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Skills</h2>
        <div class="flex flex-wrap gap-2">
          {['TypeScript', 'React', 'Node.js', 'Python', 'PostgreSQL', 'AWS'].map((skill) => (
            <span class="px-3 py-1 rounded-full bg-white/8 border border-white/10 text-cream/70 text-sm">
              {skill}
            </span>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-xs font-mono text-sky uppercase tracking-widest mb-6">Education</h2>
        <div class="border-l-2 border-white/10 pl-6">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
            <h3 class="font-semibold text-cream">Your Degree</h3>
            <span class="text-xs text-cream/40 font-mono">2020 — 2024</span>
          </div>
          <p class="text-sky/80 text-sm">University Name</p>
        </div>
      </section>

    </div>
  </div>
</PageLayout>

<SearchModal />
