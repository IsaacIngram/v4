---
import type { BlogPost } from '../lib/fetchBlogFeed';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const date = post.publishDate
  ? new Date(post.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : '';
---

<article class="group border-b border-white/8 py-5 first:border-t first:border-t-white/8">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-baseline gap-3 mb-1.5 flex-wrap">
        <a
          href={`/blog/${post.slug}`}
          class="font-mono font-semibold text-cream hover:text-sky transition-colors text-sm"
        >
          {post.title}
        </a>
        {post.tags.slice(0, 3).map((tag) => (
          <span class="font-mono text-xs text-cream/35">{tag}</span>
        ))}
      </div>
      {post.description && (
        <p class="text-cream/55 text-sm leading-relaxed line-clamp-2">{post.description}</p>
      )}
    </div>

    <div class="flex items-center gap-3 shrink-0 pt-0.5">
      {date && <time class="font-mono text-xs text-red/60 whitespace-nowrap">{date}</time>}
      <a
        href={post.externalUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Read post"
        class="text-cream/30 hover:text-red transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</article>
