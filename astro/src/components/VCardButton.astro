---
import { owner } from '../data/owner';

const ownerData = {
  name: owner.name,
  email: owner.email,
  phone: owner.phone,
  org: owner.org,
  title: owner.title,
  website: owner.website,
  photoUrl: '/profile.jpeg',
};
---

<button
  id="vcard-btn"
  class="w-full flex items-center justify-center gap-2.5 px-5 py-4 bg-red hover:bg-red-light text-cream font-semibold rounded-2xl transition-all text-[15px] active:scale-[0.98]"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
    <circle cx="9" cy="7" r="4"/>
    <line x1="19" y1="8" x2="19" y2="14"/>
    <line x1="22" y1="11" x2="16" y2="11"/>
  </svg>
  Add to Contacts
</button>

<script define:vars={{ ownerData }}>
  async function fetchPhotoBase64(url) {
    try {
      const res = await fetch(url);
      if (!res.ok) return null;
      const blob = await res.blob();
      const type = blob.type.includes('png') ? 'PNG' : 'JPEG';
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = () => {
          const b64 = reader.result.split(',')[1];
          // vCard 3.0: fold lines at 75 chars with CRLF + space continuation
          const folded = b64.match(/.{1,75}/g).join('\r\n ');
          resolve({ b64: folded, type });
        };
        reader.onerror = () => resolve(null);
        reader.readAsDataURL(blob);
      });
    } catch {
      return null;
    }
  }

  document.getElementById('vcard-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('vcard-btn');
    if (btn) btn.textContent = 'Saving…';

    const photo = await fetchPhotoBase64(ownerData.photoUrl);

    const lines = [
      'BEGIN:VCARD',
      'VERSION:3.0',
      `FN:${ownerData.name}`,
    ];

    const parts = ownerData.name.trim().split(' ');
    const first = parts[0] ?? '';
    const last = parts.slice(1).join(' ');
    lines.push(`N:${last};${first};;;`);

    if (ownerData.org)   lines.push(`ORG:${ownerData.org}`);
    if (ownerData.title) lines.push(`TITLE:${ownerData.title}`);
    if (ownerData.email) lines.push(`EMAIL;TYPE=INTERNET:${ownerData.email}`);
    if (ownerData.phone) lines.push(`TEL;TYPE=CELL:${ownerData.phone}`);
    if (ownerData.website) lines.push(`URL:${ownerData.website}`);
    if (photo) lines.push(`PHOTO;ENCODING=b;TYPE=${photo.type}:${photo.b64}`);

    lines.push('END:VCARD');

    const vcf = lines.join('\r\n');
    const blob = new Blob([vcf], { type: 'text/vcard;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'isaac-ingram.vcf';
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);

    if (btn) {
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Saved!`;
      setTimeout(() => {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg> Add to Contacts`;
      }, 2500);
    }
  });
</script>
